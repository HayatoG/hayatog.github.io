---
import '../styles/global.css';
import { profile } from '../data/portfolio';

interface Props { title?: string; description?: string; }
const {
  title = `${profile.name} (${profile.handle}) — ${profile.role}`,
  description = `Portfólio de ${profile.name} (${profile.handle}) — ${profile.role}. Flutter, Java, low-level e homebrew de Nintendo Switch.`,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content={profile.name} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content="Flutter, Java, low-level e homebrew de Nintendo Switch. Nanquim sobre creme." />
  <meta property="og:url" content={`https://${profile.domain}`} />
  <meta name="theme-color" content="#F4F2EC" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Archivo:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23F4F2EC'/%3E%3Cpath d='M16 6c3 0 5 3 5 6s-2 6-5 8c-3-2-5-5-5-8s2-6 5-6z' fill='%237E1C1C'/%3E%3C/svg%3E" />
</head>
<body>
  <!-- sakura com física real (canvas) -->
  <canvas id="sakura-canvas" aria-hidden="true"></canvas>

  <!-- cursor customizado sumê -->
  <div class="cursor" aria-hidden="true"></div>
  <div class="cursor-dot" aria-hidden="true"></div>

  <slot />

  <script>
    import '../scripts/effects.ts';
  </script>
</body>
</html>
